{
  "name": "harbor-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern docusaurus.config.ts sidebars.ts \"src/**/*.{ts,tsx}\"",
    "lint:md": "markdownlint \"docs/**/*.md\" \"versioned_docs/**/*.md\"",
    "check:links": "bash scripts/check-links.sh",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check": "pnpm lint:md && pnpm lint && pnpm typecheck && pnpm build && pnpm check:links && pnpm check:a11y"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "@mermaid-js/layout-elk": "^0.2.1",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/eslint-plugin": "3.10.1",
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "markdownlint-cli": "^0.44.0",
    "pa11y-ci": "^3.1.0",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "pnpm@10.12.1"
}
